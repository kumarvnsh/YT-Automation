# ===========================================================================
# Copy this file to ".env" and fill in your keys. NEVER commit the real .env.
# Only the keys for the providers you actually use are required.
# ===========================================================================

# --- Script writer (choose one; Anthropic is the default in config.yaml) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Stock footage / images (free key from https://www.pexels.com/api/) ---
PEXELS_API_KEY=

# --- Optional premium TTS (https://elevenlabs.io). Leave blank to use free edge-tts ---
ELEVENLABS_API_KEY=

# --- YouTube upload ---
# Path to the OAuth client secret JSON downloaded from Google Cloud Console.
# After the first run of scripts/setup_oauth.py a token is cached at secrets/token.json.
YOUTUBE_CLIENT_SECRET_FILE=secrets/client_secret.json
